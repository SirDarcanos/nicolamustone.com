---
import type { Entry } from "../lib/wordpress";

const SITE_URL = "https://nicolamustone.com";
const SITE_NAME = "Nicola Mustone";
const DEFAULT_DESCRIPTION = "Leader. Writer. Builder.";
const DEFAULT_OG_IMAGE = `${SITE_URL}/wp-content/uploads/2025/11/nicolamustone.png`;
const TWITTER_HANDLE = "@nicolamustone";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: "website" | "article";
  article?: Entry;
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  canonical = new URL(Astro.url.pathname, SITE_URL).href,
  ogImage = DEFAULT_OG_IMAGE,
  type = "website",
  article,
} = Astro.props;

const fullTitle = title === SITE_NAME ? SITE_NAME : `${title} — ${SITE_NAME}`;
const resolvedCanonical = article?.seo.canonical ?? canonical;
const resolvedOgImage = article?.seo.ogImage ?? ogImage;

// JSON-LD: WebSite + Person always; Article for posts.
const jsonLd: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_NAME,
    url: SITE_URL,
    description: DEFAULT_DESCRIPTION,
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE_NAME,
    url: SITE_URL,
    sameAs: [
      "https://bsky.app/profile/nicolamustone.bsky.social",
      "https://github.com/SirDarcanos",
      "https://indieweb.social/@nicolamustone",
      "https://profiles.wordpress.org/nicolamustone/",
      "https://www.linkedin.com/in/nicolamustone/",
      "https://x.com/nicolamustone",
    ],
  },
];

if (article) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: article.title,
    description: article.seo.description,
    url: article.seo.canonical,
    datePublished: article.date,
    dateModified: article.modified,
    ...(article.featuredImage ? { image: article.featuredImage } : {}),
    author: { "@type": "Person", name: SITE_NAME, url: SITE_URL },
    publisher: { "@type": "Person", name: SITE_NAME, url: SITE_URL },
    mainEntityOfPage: article.seo.canonical,
  });
}
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={resolvedCanonical} />

{/* Open Graph */}
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:locale" content="en_US" />
{
  article && (
    <>
      <meta property="article:published_time" content={article.date} />
      <meta property="article:modified_time" content={article.modified} />
    </>
  )
}

{/* Twitter Card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
<meta name="twitter:site" content={TWITTER_HANDLE} />
<meta name="twitter:creator" content={TWITTER_HANDLE} />

{/* JSON-LD */}
{
  jsonLd.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
