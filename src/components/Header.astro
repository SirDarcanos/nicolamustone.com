---
import Image from "../components/Image.astro";
import Nav from "../components/Nav.astro";

import avatar from "../assets/nico.jpeg";
---

<header
  class="border-line bg-surface sticky top-0 z-50 border-b py-3 text-sm drop-shadow-xs"
>
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 md:flex-row"
  >
    <div class="flex-col-2 flex items-center gap-4">
      <Image
        src={avatar}
        alt="Picture of Nicola Mustone"
        className="size-12 rounded-full object-cover"
        priority
      />
      <p id="name" class="text-lg">
        <a href="/" class="text-body font-semibold">
          Nicola Mustone<span
            id="taglie"
            class="text-faint block font-mono text-xs font-normal"
            >does things and ships them</span
          ></a
        >
      </p>
    </div>
    <Nav location="header" />
  </div>
</header>
