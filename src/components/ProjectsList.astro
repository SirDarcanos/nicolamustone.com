---
import { getAllPosts } from "../lib/wordpress";

const posts = await getAllPosts();
---

{
  posts.map((post) => {
    let img: URL | null = null;
    if (post.featuredImage) {
      img = new URL(post.featuredImage);
      img.searchParams.set("resize", "48,48");
      img.searchParams.delete("fit");
    }

    const publishDate = new Date(post.date);

    return (
      <article
        id={"post-" + post.id}
        class="border-line border-t px-2 py-7 last:border-b"
      >
        <div class="flex items-start gap-4 sm:gap-6 md:items-center">
          {img && (
            <img
              src={img.toString()}
              alt={post.featuredImageAlt}
              decoding="async"
              width="48"
              height="48"
              class="shrink-0 rounded-lg"
            />
          )}
          <div class="min-w-0 flex-1 md:flex md:items-center md:justify-between md:gap-4">
            <div>
              <h2>
                <a href={`/${post.slug}/`} class="text-ink">
                  {post.title}
                  {post.categories.map((category) => (
                    <span class="bg-accent-soft text-accent ml-2 inline-block px-2 py-1 align-middle font-mono text-xs font-light uppercase">
                      {category}
                    </span>
                  ))}
                </a>
              </h2>
              <p class="text-body">{post.excerpt}</p>
            </div>
            <div class="text-muted mt-2 flex shrink-0 gap-2 font-mono text-xs md:mt-0">
              {post.tags.map((tag) => (
                <span class="capitalize">{tag}</span>
              ))}
              &middot;
              <time datetime={post.date}>
                {publishDate.toLocaleDateString("en-RO", {
                  year: "numeric",
                  month: "short",
                })}
              </time>
            </div>
          </div>
        </div>
      </article>
    );
  })
}
