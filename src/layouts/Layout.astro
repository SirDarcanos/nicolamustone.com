---
import favicon from "../assets/nico.jpeg";
import "../styles/global.css";
import { Font } from "astro:assets";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Entry } from "../lib/wordpress";

interface Props {
  title: string;
  description?: string;
  type?: "website" | "article" | "profile";
  article?: Entry;
  noindex?: boolean;
}

const { title, description, type, article, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={favicon.src} />
    <meta name="generator" content={Astro.generator} />

    {/* Set theme before paint to avoid a flash. Dark is the default */}
    <script is:inline>
      {
        if (localStorage.getItem("theme") !== "light") {
          document.documentElement.classList.add("dark");
        }
      }
    </script>

    <Font cssVariable="--font-space-grotesk" preload />
    <Font cssVariable="--font-hanken-grotesk" preload />
    <Font cssVariable="--font-jetbrains-mono" preload />

    <SEO
      title={title}
      description={description}
      type={type}
      article={article}
      noindex={noindex}
    />
  </head>
  <body class="flex min-h-dvh flex-col">
    <a
      href="#main"
      class="border-line bg-surface text-ink sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:border focus:px-4 focus:py-2 focus:text-sm"
    >
      Skip to main content
    </a>
    <Header />
    <main
      id="main"
      tabindex="-1"
      class="mx-auto w-full max-w-5xl flex-1 px-6 focus:outline-none"
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>
