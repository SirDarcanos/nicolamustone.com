---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Entry } from "../lib/wordpress";

interface Props {
  title: string;
  description?: string;
  type?: "website" | "article";
  article?: Entry;
}

const { title, description, type, article } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <SEO
      title={title}
      description={description}
      type={type}
      article={article}
    />
  </head>
  <body class="flex min-h-dvh flex-col">
    <Header />
    <main id="main" class="mx-auto w-full max-w-5xl flex-1 px-6">
      <slot />
    </main>
    <Footer />
  </body>
</html>
