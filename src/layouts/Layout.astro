---
import "../styles/global.css";
import { Font } from "astro:assets";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Entry } from "../lib/wordpress";

interface Props {
  title: string;
  description?: string;
  type?: "website" | "article";
  article?: Entry;
}

const { title, description, type, article } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <Font cssVariable="--font-space-grotesk" preload />
    <Font cssVariable="--font-hanken-grotesk" preload />
    <Font cssVariable="--font-jetbrains-mono" preload />

    <SEO
      title={title}
      description={description}
      type={type}
      article={article}
    />
  </head>
  <body class="flex min-h-dvh flex-col">
    <Header />
    <main id="main" class="mx-auto w-full max-w-5xl flex-1 px-6">
      <slot />
    </main>
    <Footer />
  </body>
</html>
