---
import Container from "../components/Container.astro";
import Label from "../components/Label.astro";
import Layout from "../layouts/Layout.astro";
import { getAllPosts, type Entry } from "../lib/wordpress";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: {
        title: posts[(i - 1 + posts.length) % posts.length].title,
        slug: posts[(i - 1 + posts.length) % posts.length].slug,
      },
      next: {
        title: posts[(i + 1) % posts.length].title,
        slug: posts[(i + 1) % posts.length].slug,
      },
    },
  }));
}

type PostLink = { title: string; slug: string };

interface Props {
  post: Entry;
  prev: PostLink;
  next: PostLink;
}

const { post, prev, next } = Astro.props;
const publishDate = new Date(post.date);
---

<Layout
  title={post.seo.title}
  description={post.seo.description}
  type="article"
  article={post}
>
  {/* POST HEADER */}
  <article id={"post-" + post.id} class="mt-10">
    <header class="text-center md:max-w-xl md:text-left">
      <p class="font-mono text-xs">
        {
          post.tags.map((tag) => (
            <>
              <span class="text-accent capitalize">{tag}</span>
              <span class="text-faint"> / </span>
            </>
          ))
        }
        <time datetime={post.date} class="text-faint">
          {
            publishDate.toLocaleDateString("en-RO", {
              year: "numeric",
              month: "short",
            })
          }
        </time>
        {
          post.categories.map((category) => (
            <span class="bg-accent-soft text-accent ml-2 inline-block px-2 py-1 align-middle font-mono text-xs font-light uppercase">
              {category}
            </span>
          ))
        }
      </p>
      <h1 class="mt-10">{post.title}</h1>
      <p class="text-muted mt-4 text-xl">
        {post.excerpt}
      </p>
    </header>

    {/* POST CONTENT */}
    <div class="post-content mt-7" set:html={post.contentHtml} />

    {/* STACK */}
    {
      post.stack.length > 0 && (
        <Container
          section
          id="stack"
          className="border-line bg-surface rounded-xl border p-10 mt-10"
        >
          <h2 class="mono text-accent font-mono text-sm font-medium">
            THE STACK
          </h2>
          <dl class="mt-7 grid grid-cols-1 items-center gap-x-8 gap-y-7 md:grid-cols-[1fr_5fr]">
            {post.stack.map((group) => (
              <>
                <dt class="text-muted text-sm font-semibold capitalize">
                  {group.name}
                </dt>
                <dd class="flex flex-wrap gap-2">
                  {group.items.map((item) => (
                    <span class="bg-accent-soft border-line rounded-lg border px-3 py-2 font-mono text-sm">
                      {item}
                    </span>
                  ))}
                </dd>
              </>
            ))}
          </dl>
        </Container>
      )
    }

    {/* HIGHLIGHTS */}
    {
      post.highlights.length > 0 && (
        <Container section id="highlights" className="mt-10">
          <h2 class="text-2xl">Notable bits</h2>
          <ul class="mt-5 space-y-2">
            {post.highlights.map((highlight) => (
              <li class="flex items-center gap-4 capitalize">
                <span class="text-accent text-xs" aria-hidden="true">
                  →
                </span>
                {highlight}
              </li>
            ))}
          </ul>
        </Container>
      )
    }
  </article>

  <footer class="border-line mt-15 border-t py-10">
    <nav class="flex gap-6">
      <a
        href={`/${prev.slug}`}
        class="border-line bg-surface text-body flex-1 rounded-lg border p-6 text-left font-semibold"
        ><span class="text-faint text-xs">← Previous</span><br />{prev.title}</a
      >
      <a
        href={`/${next.slug}`}
        class="border-line bg-surface text-body flex-1 rounded-lg border p-6 text-right font-semibold"
        ><span class="text-faint text-xs">Next →</span><br />{next.title}</a
      >
    </nav>
  </footer>
</Layout>
