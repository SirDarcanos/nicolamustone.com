---
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import Label from "../components/Label.astro";
import Layout from "../layouts/Layout.astro";
import Job from "../components/Job.astro";
import ProjectsList from "../components/ProjectsList.astro";
import pkg from "number-to-words";

import { getAllPosts } from "../lib/wordpress";
import { jobs, yearsInCareer } from "../data/data";

const posts = await getAllPosts();

const { toWords } = pkg;
const yearsWord =
  toWords(yearsInCareer)[0].toUpperCase() + toWords(yearsInCareer).slice(1);
---

<Layout title="Nicola Mustone - Does things and ships them" type="website">
  {/* INTRO */}
  <Container
    section
    id="intro"
    className="text-center md:max-w-xl md:text-left"
  >
    <Label>
      {posts.length} things & counting
    </Label>
    <h1 class="mt-4">I lead, write, build, and actually ship things.</h1>
    <p class="mt-5 text-lg">
      I'm Nico — Support Lead at Automattic by day, and a maker of small, sharp,
      occasionally silly things the rest of the time. These are the ones I care
      about right now.
    </p>
  </Container>

  {/* PROJECTS */}
  <Container id="projects">
    <ProjectsList />
  </Container>

  {/* EXPERIENCE */}
  <Container
    section
    id="experience"
    className="border-line bg-surface rounded-xl border p-6 md:p-10"
  >
    <Label>My experience</Label>
    <div
      class="mt-2 flex flex-col items-start justify-between gap-4 md:flex-row md:items-center"
    >
      <h2>
        {yearsWord} years of code, tickets & leadership.
      </h2>
      <Button href="/about/" ghost>Read the full story</Button>
    </div>

    {/* TIMELINE */}
    <div class="mt-10 grid grid-cols-1 md:grid-cols-4">
      {jobs.filter((job) => !job.hideOnIndex).map((job) => <Job {...job} />)}
    </div>
  </Container>
</Layout>
