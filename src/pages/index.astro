---
/**
 * Home page (hub). Minimal version — full hub layout is Phase 2.6.
 * Lists the project posts so the homepage is real and the SEO/sitemap wiring
 * can be verified end to end.
 */
import Layout from "../layouts/Layout.astro";
import { getAllPosts } from "../lib/wordpress";

const posts = await getAllPosts();
---

<Layout title="Nicola Mustone" type="website">
  <main>
    <h1>Nicola Mustone</h1>
    <p>Leader. Writer. Builder.</p>
    <ul>
      {
        posts.map((post) => (
          <li>
            <a href={`/${post.slug}`}>{post.title}</a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
