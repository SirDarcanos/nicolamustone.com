---
import Container from "../components/Container.astro";
import Layout from "../layouts/Layout.astro";
import Label from "../components/Label.astro";
import Stat from "../components/Stat.astro";

import { stats } from "../data/data";
---

<Layout title="About">
  {/* INTRO */}
  <Container
    section
    id="intro"
    className="space-y-4 text-center md:max-w-xl md:text-left"
  >
    <Label> A short CV </Label>
    <h1 id="name" class="mt-3 mb-10 text-4xl">Hi, I'm Nico.</h1>
    <p>
      I've spent over a decade at the intersection of technology, communication,
      and leadership — learning how clear systems and good writing make both
      teams and products stronger.
    </p>
    <p>
      Today I'm a Support Lead at Automattic, helping people and teams get the
      most out of WordPress.com and WooCommerce. When I'm not in a support
      dashboard, I'm building small sites, running D&D adventures, or cooking
      something I have strong opinions about.
    </p>
  </Container>

  {/* STATS */}
  <Container id="stats" className="grid grid-cols-5 gap-2">
    {stats.map((stat) => <Stat {...stat} />)}
  </Container>
</Layout>
