---
import Container from "../components/Container.astro";
import Layout from "../layouts/Layout.astro";
import Label from "../components/Label.astro";
import SkillBadge from "../components/SkillBadge.astro";
import Stat from "../components/Stat.astro";
import TimelineEntry from "../components/TimelineEntry.astro";

import { jobs, stats, skills } from "../data/data";

const skillGroups = [
  { title: "Humans", label: "Leading & Coaching", items: skills.human },
  { title: "Machines", label: "Building & Code", items: skills.tech },
  { title: "Exploring", label: "Curiosity & Data", items: skills.exploring },
];
---

<Layout title="About">
  {/* INTRO */}
  <Container
    section
    id="intro"
    className="space-y-4 text-center md:max-w-xl md:text-left"
  >
    <Label>All about me</Label>
    <h1 id="name" class="mt-3 mb-10 text-4xl">Hi, I'm Nico.</h1>
    <p>
      I've spent over a decade at the intersection of technology, communication,
      and leadership — learning how clear systems and good writing make both
      teams and products stronger.
    </p>
    <p>
      Today I'm a Support Lead at Automattic, helping people and teams get the
      most out of WordPress.com and WooCommerce. When I'm not in a support
      dashboard, I'm building small sites, running D&D adventures, or cooking
      something I have strong opinions about.
    </p>
  </Container>

  {/* STATS */}
  <Container
    id="stats"
    className="grid grid-cols-1 gap-2 text-center md:grid-cols-3 md:text-left lg:grid-cols-5"
  >
    {stats.map((stat) => <Stat {...stat} />)}
  </Container>

  {/* SKILLS STACK */}
  <Container section id="skills">
    <h2>What I work with</h2>

    {
      skillGroups.map((group) => (
        <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-[1fr_3fr]">
          <section>
            <h3 class="text-lg">{group.title}</h3>
            <p class="text-accent mt-1 font-mono text-xs uppercase">
              {group.label}
            </p>
          </section>
          <div class="flex flex-wrap gap-2">
            {group.items.map((skill) => (
              <SkillBadge>{skill}</SkillBadge>
            ))}
          </div>
        </div>
      ))
    }
  </Container>

  {/* EXPERIENCE */}
  <Container section id="experience">
    <h2>My experience</h2>
    <div class="mt-10">
      {jobs.map((job) => <TimelineEntry {...job} />)}
    </div>
  </Container>
</Layout>
